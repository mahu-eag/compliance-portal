{
  "routes": [
    {
      "route": "/api/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/nis-2/*",
      "serve": "/nis-2/index.html",
      "statusCode": 200
    },
    {
      "route": "/eu-ai-act/*",
      "serve": "/eu-ai-act/index.html",
      "statusCode": 200
    },
    {
      "route": "/itq/*",
      "serve": "/itq/index.html",
      "statusCode": 200
    },
    {
      "route": "/*",
      "serve": "/index.html",
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/nis-2/*", "/eu-ai-act/*", "/itq/*", "/api/*"]
  },
  "globalHeaders": {
    "Cache-Control": "no-cache"
  }
}
