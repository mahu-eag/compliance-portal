# ── SMTP-Konfiguration ───────────────────────────────────────────────────
# Kopieren Sie diese Datei zu .env und tragen Sie Ihre Zugangsdaten ein.
# Die .env-Datei wird NICHT ins Git eingecheckt.

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=ihre-adresse@ihredomain.de
SMTP_PASSWORD=IhrPasswort

# Absender-Name und -Adresse (erscheint im "Von"-Feld)
MAIL_FROM="elpix Compliance Assessment" <ihre-adresse@ihredomain.de>

# Interne Benachrichtigungen (erhält dieselbe E-Mail wie der Kunde)
MAIL_TO_INTERNAL=intern@ihredomain.de

# Lokaler Server-Port
API_PORT=3001
